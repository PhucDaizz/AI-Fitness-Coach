# ─── App ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# ─── MongoDB ────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/ai-fitness-coach

# ─── Redis ──────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── RabbitMQ ───────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_QUEUE_PLAN_GENERATED=plan.generated
RABBITMQ_QUEUE_PLAN_ADJUSTED=plan.adjusted
RABBITMQ_QUEUE_WORKOUT_FEEDBACK=workout.feedback

# ─── JWT (.NET Auth Service signs the token) ────────────
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# ─── CORS ───────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── Rate Limit ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100